# Generate independent random values for each environment. Do not commit real secrets.
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
APP_SECRET_KEY=replace-with-a-valid-fernet-key-generated-by-Fernet.generate_key

# Production defaults
ENABLE_DEMO_SEED=0
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password-of-at-least-12-characters
INITIAL_ADMIN_EMAIL=admin@example.com
APP_HOST=127.0.0.1
APP_PORT=8001
CORS_ORIGINS=https://your-frontend.example.com
WORKFLOW_CODE_EXECUTION_ENABLED=0
SSRF_ALLOWED_PORTS=80,443
SSRF_ALLOWED_HOSTS=api.example.com
SSRF_ALLOW_INTERNAL=0

# Optional OpenAI-compatible chat model for digital employees.
# Fill CHAT_MODEL_API_KEY manually, then restart the service.
# Examples:
#   OpenAI:   CHAT_MODEL_ENDPOINT=https://api.openai.com/v1, CHAT_MODEL_NAME=gpt-4o-mini
#   DeepSeek: CHAT_MODEL_ENDPOINT=https://api.deepseek.com/v1, CHAT_MODEL_NAME=deepseek-chat
CHAT_MODEL_API_KEY=
CHAT_MODEL_ENDPOINT=https://api.openai.com/v1
CHAT_MODEL_NAME=gpt-4o-mini
CHAT_MODEL_PROVIDER=OpenAI-Compatible
CHAT_MODEL_DISPLAY_NAME=演示对话模型
CHAT_MODEL_CONTEXT_LENGTH=128000
CHAT_MODEL_TEMPERATURE=0.7
CHAT_MODEL_MAX_TOKENS=4096
